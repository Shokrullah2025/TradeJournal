# Environment Configuration for Trade Journal Pro
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# -------------------------------------------------------
# SUPABASE (required — get these from your Supabase project dashboard)
# -------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# -------------------------------------------------------
# STRIPE (frontend publishable key only — secret key goes in Edge Functions)
# -------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# -------------------------------------------------------
# BROKER OAUTH — client IDs are safe to expose (VITE_ prefix)
# Client secrets must NEVER go here — put them in Supabase Edge Function env vars
# -------------------------------------------------------
VITE_TRADOVATE_DEMO_CLIENT_ID=your-demo-client-id
VITE_TRADOVATE_LIVE_CLIENT_ID=your-live-client-id
VITE_ALPACA_CLIENT_ID=your-alpaca-client-id

# -------------------------------------------------------
# MARKET DATA — free keys for Backtest chart data
# Crypto:   Binance — no key needed, works automatically
# Daily:    Alpha Vantage (free) — get key at https://alphavantage.co
# Intraday: Twelve Data (free 800/day) — get key at https://twelvedata.com/pricing
# -------------------------------------------------------
VITE_ALPHA_VANTAGE_KEY=your_free_alpha_vantage_key_here
VITE_TWELVE_DATA_KEY=your_free_twelve_data_key_here

# -------------------------------------------------------
# LOCAL DEV (Vite dev server)
# -------------------------------------------------------
VITE_APP_ENV=development

# -------------------------------------------------------
# SECRETS — set these in Supabase Dashboard → Project Settings → Edge Functions.
# NEVER put them here with a VITE_ prefix — they would end up in the JS bundle.
# -------------------------------------------------------
# In Supabase Edge Function env vars (not this file):
#
#   TRADOVATE_DEMO_CLIENT_ID=...
#   TRADOVATE_DEMO_CLIENT_SECRET=...
#   TRADOVATE_LIVE_CLIENT_ID=...
#   TRADOVATE_LIVE_CLIENT_SECRET=...
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
#   ALPACA_CLIENT_SECRET=...
#   RESEND_API_KEY=re_...
