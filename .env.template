# Multi-User OAuth Environment Setup
# Copy this file to .env and fill in your values. NEVER commit .env to git.
#
# SECURITY RULE: VITE_ prefixed variables are compiled into the JS bundle and
# visible to every user in browser DevTools. Only client IDs and publishable
# keys belong here. Client secrets MUST go in Supabase Edge Function env vars
# (Supabase Dashboard → Project → Edge Functions → Secrets).

# ================================
# SUPABASE (required)
# ================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ================================
# BROKER OAUTH — client IDs only (safe to expose)
# ================================
# Register ONE app with each broker. Client IDs are public identifiers.
# Each of your users authenticates through your registered app and gets
# their own isolated access token stored server-side in broker_tokens.

VITE_TRADOVATE_DEMO_CLIENT_ID=your-demo-app-client-id
VITE_TRADOVATE_LIVE_CLIENT_ID=your-live-app-client-id
VITE_ALPACA_CLIENT_ID=your-alpaca-client-id
VITE_IB_CLIENT_ID=your-ib-client-id

# ================================
# STRIPE — publishable key only (safe to expose)
# ================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ================================
# MARKET DATA — free keys
# ================================
VITE_ALPHA_VANTAGE_KEY=your_free_alpha_vantage_key_here
VITE_TWELVE_DATA_KEY=your_free_twelve_data_key_here

# ================================
# SECRETS — DO NOT PUT THESE HERE WITH VITE_ PREFIX
# Set them in: Supabase Dashboard → Project → Edge Functions → Secrets
# ================================
#
#   TRADOVATE_DEMO_CLIENT_SECRET=...
#   TRADOVATE_LIVE_CLIENT_SECRET=...
#   ALPACA_CLIENT_SECRET=...
#   IB_CLIENT_SECRET=...
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
#   RESEND_API_KEY=re_...
