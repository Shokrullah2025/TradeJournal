# Cloudflare Pages reads this file automatically to set response headers.
# Vite copies everything in public/ to the root of dist/ at build time.
#
# index.html must never be cached: it points at the hashed JS/CSS bundle for
# the current deploy. If a browser caches index.html, it keeps loading an old
# bundle after a new deploy (e.g. the "Missing VITE_SUPABASE_URL" stale-bundle
# issue). Forcing revalidation makes returning users always get the newest build.
/index.html
  Cache-Control: no-cache, max-age=0, must-revalidate

# Hashed build assets are safe to cache forever — their filenames change every
# build, so a new deploy is fetched as a brand-new URL, never a stale one.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
