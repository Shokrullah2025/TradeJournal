# Cloudflare Pages routing.
#
# The presence of dist/404.html switches Pages out of blanket SPA mode:
# unmatched paths get a real HTTP 404 (Bing/Google guideline — no soft 404s)
# instead of index.html with 200. The client-side app routes below must
# therefore be rewritten to the SPA shell explicitly. Keep this list in sync
# with the route table in src/App.jsx; a missing entry breaks deep links to
# that page in production.
#
# Prerendered marketing/legal pages are physical files in dist/ and are
# served before these rules run — they never hit this file.

/login /index.html 200
/register /index.html 200
/verify-email /index.html 200
/auth/* /index.html 200
/security/* /index.html 200
/dashboard /index.html 200
/dashboard/* /index.html 200
/trades /index.html 200
/trades/* /index.html 200
/trade-entry /index.html 200
/trade-entry/* /index.html 200
/backtest /index.html 200
/backtest/* /index.html 200
/brokers /index.html 200
/brokers/* /index.html 200
/analytics /index.html 200
/analytics/* /index.html 200
/risk-calculator /index.html 200
/settings /index.html 200
/settings/* /index.html 200
/profile /index.html 200
/billing /index.html 200
/admin /index.html 200
/admin/* /index.html 200
